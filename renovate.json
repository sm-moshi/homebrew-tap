{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>sm-moshi/infra//.github/renovate/base",
    "config:best-practices",
    ":semanticCommits",
    ":automergeMinor"
  ],
  "dependencyDashboardApproval": true,
  "assignees": [ "sm-moshi" ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "BetterDiscord cask — GitHub releases",
      "managerFilePatterns": [
        "/^Casks/betterdiscord\\.rb$/"
      ],
      "matchStrings": [
        "version \"(?<currentValue>\\d+\\.\\d+\\.\\d+)\""
      ],
      "depNameTemplate": "BetterDiscord/Installer",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "ExifCleaner cask — GitHub releases",
      "managerFilePatterns": [
        "/^Casks/exifcleaner\\.rb$/"
      ],
      "matchStrings": [
        "version \"(?<currentValue>\\d+\\.\\d+\\.\\d+)\""
      ],
      "depNameTemplate": "szTheory/exifcleaner",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Headlamp cask — GitHub releases",
      "managerFilePatterns": [
        "/^Casks/headlamp\\.rb$/"
      ],
      "matchStrings": [
        "version \"(?<currentValue>\\d+\\.\\d+\\.\\d+)\""
      ],
      "depNameTemplate": "kubernetes-sigs/headlamp",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Zenmap cask — nmap.org releases",
      "managerFilePatterns": [
        "/^Casks/zenmap\\.rb$/"
      ],
      "matchStrings": [
        "version \"(?<currentValue>\\d+\\.\\d+)\""
      ],
      "depNameTemplate": "nmap/nmap",
      "datasourceTemplate": "github-tags",
      "extractVersionTemplate": "^nmap-(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "fast-cli formula — npm registry",
      "managerFilePatterns": [
        "/^Formula/fast-cli\\.rb$/"
      ],
      "matchStrings": [
        "url \"https://registry\\.npmjs\\.org/fast-cli/-/fast-cli-(?<currentValue>\\d+\\.\\d+\\.\\d+)\\.tgz\""
      ],
      "depNameTemplate": "fast-cli",
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "description": "Group all cask updates together",
      "matchFileNames": [ "Casks/**" ],
      "groupName": "cask updates",
      "commitMessageTopic": "cask {{depName}}"
    },
    {
      "description": "Formula updates get individual PRs",
      "matchFileNames": [ "Formula/**" ],
      "commitMessageTopic": "formula {{depName}}"
    },
    {
      "description": "Headlamp is disabled — suppress updates",
      "matchDepNames": [ "kubernetes-sigs/headlamp" ],
      "enabled": true
    }
  ]
}
